# 복사해서 .env 로 쓰세요 (.env 는 커밋되지 않습니다)

# ── 데이터 경로 ──
DATA_DIR=./data

# ── 서빙 API ──
# RELOAD_INTERVAL_SECONDS=600   # store 자동 리로드 주기(초), 0 이면 비활성

# ── 크롤러 동작 ──
# CRAWL_USER_AGENT=Mozilla/5.0 (compatible; new-zip-dao/0.1)
CRAWL_TIMEOUT=30
CRAWL_RATE_LIMIT=1          # 초당 요청 수 (사이트 부하 보호, 코드 기본값 1)

# ── 공공데이터포털 API — lh_apply·applyhome·myhome·gh 소스에 필수 ──
# 키 발급 후 각 데이터셋(15058530·15098547·15108420·15119414) 활용신청 필요
DATA_GO_KR_SERVICE_KEY=

# ── 선택: Google Drive 백업(rclone) ──
GDRIVE_REMOTE=gdrive
GDRIVE_FOLDER_ID=1GcJb7hMD4XmxJNdrTF3nQsuyyOUnyUDf
