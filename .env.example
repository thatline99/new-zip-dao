# 복사해서 .env 로 쓰세요 (.env 는 커밋되지 않습니다)

# ── 데이터 경로 ──
DATA_DIR=./data

# ── 크롤러 동작 ──
# CRAWL_USER_AGENT=Mozilla/5.0 (compatible; new-zip-dao/0.1)
CRAWL_TIMEOUT=30
CRAWL_RATE_LIMIT=2          # 초당 요청 수 (사이트 부하 보호)

# ── 선택: 공공데이터포털 API (청약홈/LH 보조 수집 시) ──
DATA_GO_KR_SERVICE_KEY=

# ── 선택: Google Drive 백업(rclone) ──
GDRIVE_REMOTE=gdrive
GDRIVE_FOLDER_ID=1GcJb7hMD4XmxJNdrTF3nQsuyyOUnyUDf
